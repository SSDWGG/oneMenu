<Page x:Class="OneMenu.App.Pages.TargetTimePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Margin="0,20,0,0">
        <TextBlock Text="目标倒计" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,6"/>
        <TextBlock Text="到点分钟" FontSize="11" Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" Margin="0,0,0,20"/>

        <TextBlock Text="标题" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,4"/>
        <TextBox x:Name="TitleBox" Width="200" HorizontalAlignment="Left" FontSize="13"
                 TextChanged="OnTitleChanged" Margin="0,0,0,16"/>

        <TextBlock Text="目标时间" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8"/>
        <StackPanel Orientation="Horizontal">
            <TextBox x:Name="HourBox" Width="60" TextAlignment="Right" FontSize="13"
                     TextChanged="OnHourChanged" Margin="0,0,8,0"/>
            <TextBlock Text=":" FontSize="13" VerticalAlignment="Center" Margin="0,0,8,0"/>
            <TextBox x:Name="MinuteBox" Width="60" TextAlignment="Right" FontSize="13"
                     TextChanged="OnMinuteChanged" Margin="0,0,8,0"/>
        </StackPanel>

        <TextBlock Text="过点行为" FontSize="13" FontWeight="SemiBold" Margin="0,20,0,8"/>
        <ComboBox x:Name="PastBehaviorCombo" Width="160" HorizontalAlignment="Left"
                  SelectionChanged="OnPastBehaviorChanged" DisplayMemberPath="Title"/>

        <TextBlock Text="背景颜色" FontSize="13" FontWeight="SemiBold" Margin="0,20,0,8"/>
        <ComboBox x:Name="BgColorCombo" Width="160" HorizontalAlignment="Left"
                  SelectionChanged="OnBgColorChanged">
            <ComboBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal">
                        <Rectangle Width="14" Height="14" Fill="{Binding WpfBrush}" RadiusX="4" RadiusY="4" Margin="0,0,8,0"/>
                        <TextBlock Text="{Binding Title}" VerticalAlignment="Center"/>
                    </StackPanel>
                </DataTemplate>
            </ComboBox.ItemTemplate>
        </ComboBox>

        <TextBlock Text="文字粗细" FontSize="13" FontWeight="SemiBold" Margin="0,20,0,8"/>
        <ComboBox x:Name="TextWeightCombo" Width="160" HorizontalAlignment="Left"
                  SelectionChanged="OnTextWeightChanged" DisplayMemberPath="Title"/>

        <TextBlock Text="文字颜色" FontSize="13" FontWeight="SemiBold" Margin="0,20,0,8"/>
        <ComboBox x:Name="TextColorCombo" Width="160" HorizontalAlignment="Left"
                  SelectionChanged="OnTextColorChanged">
            <ComboBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal">
                        <Rectangle Width="14" Height="14" Fill="{Binding WpfBrush}" RadiusX="4" RadiusY="4" Margin="0,0,8,0"/>
                        <TextBlock Text="{Binding Title}" VerticalAlignment="Center"/>
                    </StackPanel>
                </DataTemplate>
            </ComboBox.ItemTemplate>
        </ComboBox>

        <CheckBox x:Name="ShowIconCheck" Content="显示图标" FontSize="13"
                  Checked="OnShowIconChanged" Unchecked="OnShowIconChanged" Margin="0,20,0,0"/>
    </StackPanel>
</Page>
