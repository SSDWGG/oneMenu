<Page x:Class="OneMenu.App.Pages.ColorSettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Margin="0,20,0,0">
        <TextBlock Text="{Binding Title}" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,6"/>
        <TextBlock Text="菜单栏状态指示灯颜色" FontSize="11" Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" Margin="0,0,0,20"/>

        <TextBlock Text="活跃状态指示灯" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8"/>
        <ComboBox x:Name="RunningColorCombo"
                  Width="160" HorizontalAlignment="Left"
                  SelectionChanged="OnRunningColorChanged">
            <ComboBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal">
                        <Rectangle Width="14" Height="14" Fill="{Binding WpfBrush}" RadiusX="7" RadiusY="7" Margin="0,0,8,0"/>
                        <TextBlock Text="{Binding Title}" VerticalAlignment="Center"/>
                    </StackPanel>
                </DataTemplate>
            </ComboBox.ItemTemplate>
        </ComboBox>

        <TextBlock Text="空闲状态指示灯" FontSize="13" FontWeight="SemiBold" Margin="0,20,0,8"/>
        <ComboBox x:Name="IdleColorCombo"
                  Width="160" HorizontalAlignment="Left"
                  SelectionChanged="OnIdleColorChanged">
            <ComboBox.ItemTemplate>
                <DataTemplate>
                    <StackPanel Orientation="Horizontal">
                        <Rectangle Width="14" Height="14" Fill="{Binding WpfBrush}" RadiusX="7" RadiusY="7" Margin="0,0,8,0"/>
                        <TextBlock Text="{Binding Title}" VerticalAlignment="Center"/>
                    </StackPanel>
                </DataTemplate>
            </ComboBox.ItemTemplate>
        </ComboBox>
    </StackPanel>
</Page>
