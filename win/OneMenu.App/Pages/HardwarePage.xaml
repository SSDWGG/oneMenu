<Page x:Class="OneMenu.App.Pages.HardwarePage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <StackPanel Margin="0,20,0,0">
        <TextBlock Text="硬件" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,6"/>
        <TextBlock Text="系统状态显示 (点击刷新)" FontSize="11" Foreground="{DynamicResource {x:Static SystemColors.GrayTextBrushKey}}" Margin="0,0,0,20"/>

        <TextBlock Text="菜单栏显示指标" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8"/>
        <ComboBox x:Name="MetricCombo" Width="200" HorizontalAlignment="Left"
                  SelectionChanged="OnMetricChanged" Margin="0,0,0,20"/>

        <TextBlock Text="实时状态" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8"/>
        <StackPanel x:Name="StatusPanel">
            <TextBlock x:Name="CpuLabel" FontSize="12" FontFamily="Consolas" Margin="0,2,0,0"/>
            <TextBlock x:Name="MemoryLabel" FontSize="12" FontFamily="Consolas" Margin="0,2,0,0"/>
            <TextBlock x:Name="BatteryLabel" FontSize="12" FontFamily="Consolas" Margin="0,2,0,0"/>
            <TextBlock x:Name="ThermalLabel" FontSize="12" FontFamily="Consolas" Margin="0,2,0,0"/>
            <TextBlock x:Name="GpuLabel" FontSize="12" FontFamily="Consolas" Margin="0,2,0,0"/>
        </StackPanel>

        <Button Content="刷新" Width="80" HorizontalAlignment="Left" Margin="0,12,0,0"
                Click="OnRefreshClick"/>
    </StackPanel>
</Page>
