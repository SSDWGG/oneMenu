<UserControl x:Class="OneMenu.App.Controls.ColorPicker"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Border BorderBrush="{DynamicResource {x:Static SystemColors.ActiveBorderBrushKey}}"
            BorderThickness="1" CornerRadius="6"
            Padding="10" Margin="0,0,0,10">
        <StackPanel>
            <TextBlock x:Name="HeaderLabel" FontSize="13" FontWeight="SemiBold"
                       Foreground="{DynamicResource {x:Static SystemColors.ControlTextBrushKey}}"
                       Margin="0,0,0,8"/>
            <ComboBox x:Name="ColorCombo"
                      Height="32"
                      SelectionChanged="OnColorChanged"
                      DisplayMemberPath="Title"/>
        </StackPanel>
    </Border>
</UserControl>
